{
  "name": "yuedu-reader",
  "version": "1.0.0",
  "description": "悦读 - 小说阅读器，支持老板键、迷你窗口、AI净化",
  "main": "dist-electron/main/index.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build && electron-builder",
    "build:win": "vite build && electron-builder --win",
    "preview": "vite preview",
    "electron:dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "electron",
    "reader",
    "novel",
    "txt",
    "qclaw"
  ],
  "author": "YueDu",
  "license": "MIT",
  "dependencies": {
    "chardet": "0.7.0",
    "electron-store": "8.2.0",
    "iconv-lite": "0.6.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "uuid": "9.0.1",
    "zustand": "4.5.2"
  },
  "devDependencies": {
    "@ant-design/icons": "5.3.0",
    "@types/node": "20.11.0",
    "@types/react": "18.3.1",
    "@types/react-dom": "18.3.0",
    "@vitejs/plugin-react": "4.2.1",
    "antd": "5.15.0",
    "asar": "3.2.5",
    "autoprefixer": "10.4.18",
    "concurrently": "8.2.2",
    "electron": "28.2.0",
    "electron-builder": "24.13.3",
    "esbuild": "0.20.1",
    "postcss": "8.4.35",
    "tailwindcss": "3.4.1",
    "typescript": "5.3.3",
    "vite": "5.2.0",
    "vite-plugin-electron": "0.28.4",
    "vite-plugin-electron-renderer": "0.14.5",
    "wait-on": "7.2.0"
  },
  "build": {
    "appId": "com.yuedu.reader",
    "productName": "悦读",
    "directories": {
      "output": "release-v3"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "resources/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        {
          "target": "dir",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "resources/icons/icon.ico",
      "sign": false
    },
    "asar": true
  }
}